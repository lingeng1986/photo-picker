{
  "preprocessing": {
    "blur_threshold": 40,
    "burst_window_seconds": 2.0,
    "thumbnail_max_size": 1024
  },
  "ai_evaluation": {
    "model": "llava:13b",
    "timeout_seconds": 60,
    "batch_size": 4
  },
  "selection": {
    "weights": {
      "eyes_open": 8,
      "expression_natural": 6,
      "eye_contact": 4,
      "quality": 3,
      "lighting": 4,
      "composition": 2
    }
  },
  "output": {
    "copy_not_selected": true
  },
  "detector": {
    "model": "assets/models/face_detection_yunet_2023mar.onnx",
    "score_threshold": 0.6,
    "nms_threshold": 0.5,
    "top_k": 5000
  }
}
